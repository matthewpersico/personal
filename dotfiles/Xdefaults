!
! $HOME/.Xdefaults
!
! This file contains user defaults resources which are applied to
! all X-clients.
!


! The Athena Widgets provided by Data General have 2 look-and-feels
! to choose from (athena and motif).  The following resource sets
! the look-and-feel:

*lookAndFeel: motif


! The following resources sets the background for all X-clients
! except mwm, for which the internal defaults will be used.
! In X11R5, the leading '?' in first resource specification,
! "?*Background", matches all application classes, and takes
! precedence over any specification starting with '*'.  The
! second resource specification '*Background' is provided for
! X11R4 applications.

#ifdef COLOR
!?*Background: lightSteelBlue
!*Background: lightSteelBlue
! Mwm*Background: darkblue xterm
#endif

! The following sets the customization resource to get
! special app-defaults, if they exist:

#ifdef COLOR
*Customization: -color
#else
*Customization: -mono
#endif

! =-=- Locally added -=-=

! Set xterms to not autoscroll unless you are at the bottom.
! Better than CTRL-S, which suspends the process.
xterm*autoScrollLock:  true
xterm*scrollTtyOutput: false
xterm*scrollKey:       true
! Other config
xterm*loginShell:true
xterm*saveLines: 16384
xterm*faceName: Consolas
xterm*faceSize: 12
xterm*scrollBar: true
xterm*scrollLines: 40000
xterm*rightScrollBar: true

*scrollbar*width:12
Emacs.ScrollBarWidth:12
Emacs.GutterWidth:12
Emacs.FringeWidth:12

*font: 10x20

! Perl Tk Debugger XResources.
! Note... These resources are subject to change.
!
! Use 'xfontsel' to select different fonts.
!
! Append these resource to ~/.Xdefaults | ~/.Xresources
! and use xrdb -override ~/.Xdefaults | ~/.Xresources
! to activate them.

! Set Value to se to place scrollbars on the right side of windows
! CAUTION:  extra whitespace at the end of the line is causing
! failures with Tk800.011.
ptkdb*scrollbars: sw

! controls where the code pane is oriented, down the left side, or across the top
! values can be set to left, right, top, bottom
ptkdb*codeside: left

!ptkdb*font: Inconsolata
!-adobe-courier-medium-r-normal--12-120-75-75-m-70-iso8859-1
!-b&h-lucidatypewriter-bold-r-normal-sans-14-100-100-100-m-80-iso8859-1
!10x20

! 10x20

! Background color for the balloon
! CAUTION:  For certain versions of Tk trailing
! characters after the color produces an error
ptkdb.frame2.frame1.rotext.balloon.background: green
! Hot Variable Balloon Font
!ptkdb.frame2.frame1.rotext.balloon.font: Inconsolata

! Menu Bar
!ptkdb.frame*font:  10x20
! File menu
!ptkdb.frame.menubutton.font:  10x20
! Code Pane
ptkdb.frame2.frame1.rotext.font:  Inconsolata
! Expression Notebook Page
ptkdb.notebook.datapage.frame1.hlist.font: Inconsolata

! Subroutine Notebook Page
ptkdb.notebook.subspage*font:  Inconsolata
! Delete Breakpoint Buttons
!ptkdb.notebook.brkptspage*entry.font:
! Breakpoint Expression Entries
!ptkdb.notebook.brkptspage*button.font:
! Breakpoint Expression Entries
ptkdb.notebook.brkptspage*button1.font:  Inconsolata
! Breakpoint Checkbuttons
!ptkdb.notebook.brkptspage*checkbutton.font:
! Breakpoint "Cond" label
!ptkdb.notebook.brkptspage*label.font:

! Eval Expression Entry Window
ptkdb.toplevel.frame.textundo.font:  Inconsolata
! Eval Expression Results Window
ptkdb.toplevel.frame1.text.font:  Inconsolata
! "Eval..." Button
!ptkdb.toplevel.button.font:
! "Clear Eval" Button
!ptkdb.toplevel.button1.font:
! "Clear Results" Button
!ptkdb.toplevel.button2.font:
! "Clear Dismiss" Button
!ptkdb.toplevel.button3.font:

! Background color for where the debugger has stopped
!ptkdb*stopcolor: blue

! Background color for set breakpoints
!ptkdb*breaktagcolor: darkred

! Font for where the debugger has stopped
!ptkdb*stopfont:

! Background color for the search tag
!ptkdb*searchtagcolor: darkgreen
