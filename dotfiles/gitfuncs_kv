[serverid]
	github = github
	gitlab = gitlab
[svcs]
	github = git@github.com:
	gitlab = git@gitlab.com:
[urls]
	github = https://github.com/
	gitlab = https://gitlab.com/
[browser-urls]
	github = https://github.com
	gitlab = https://gitlab.com
[api-urls]
	github = https://api.github.com
	gitlab = https://api.gitlab.com
[token-file]
	github = <HOME>/.config/.github-pat
	gitlab = <HOME>/.config/.gitlab-pat
[remote-users]
	github = matthewpersico
	gitlab = matthewpersico
[locs-extra]
	personal = <HOME>/personal:depth=3
	emacsd = <HOME>/.emacs.d:depth=3
	emacsdtaps = <HOME>/.emacs.d/taps/matthew:depth=3
	examples = <HOME>/examples:depth=3
