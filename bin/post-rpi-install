# -*- sh -*-
# shellcheck shell=bash

## post-rpi-install
declare ceid='post-rpi-install'

## Instructions to build an environment after a new RPI install.
## Run as 'matthew'; 'sudo' will be used where necessary.

## Create a workspace
sudo mkdir -p /opt/mop
sudo chown matthew /opt/mop
declare install_workdir
install_workdir=/opt/mop/$(basename "$0")
mkdir -p "$install_workdir"
cd "$install_workdir" || exit

## Update the system
cmd-echo --id $ceid 'Update the system'
sudo apt update
sudo apt upgrade

## Add email support, primarily for cron
cmd-echo --id $ceid 'Add email support, primarily for cron'

sudo apt install ssmtp -y

cat <<EOSSMTPCONF > ssmtp.conf
root=matthew.persico@gmail.com
mailhub=smtp.gmail.com:587
hostname=rpi5-rpi.localdomain
FromLineOverride=YES
AuthUser=matthew.persico@gmail.com
AuthPass=$(cat "$HOME"/.config/GMail*.txt)
UseSTARTTLS=YES
EOSSMTPCONF

sudo chown root:root ssmtp.conf
sudo chmod 640 ssmtp.conf
sudo mv ssmtp.conf /etc/ssmtp/ssmtp.conf
sudo ls -lart /etc/ssmtp/ssmtp.conf
sudo cat /etc/ssmtp/ssmtp.conf

cat <<EOREVALIASES > revaliases
root:root@rpi5-rpi:smtp.gmail.com:587
matthew:matthew@rpi5-rpi:smtp.gmail.com:587
EOREVALIASES

sudo chown root:root revaliases
sudo chmod 640 revaliases
sudo mv revaliases /etc/ssmtp/revaliases
sudo ls -la /etc/ssmtp/revaliases
sudo cat /etc/ssmtp/revaliases

cmd-echo --id $ceid 'Testing email setup'
ssmtp matthew.persico@gmail.com <<EOD
Subject: This is a test
Line 1
Line 2
Line 3
EOD

if ! grep -q 'Matthew Persico' /etc/passwd; then
    cmd-echo --id $ceid 'Name "Matthew Persico" not found in /etc/passwd. Add it...'
    sleep 2
    sudo vi /etc/passwd
fi

## Install debian packages
cmd-echo --id $ceid 'Install debian packages'
declare -a debian_packages=(
    curl
    x11-xserver-utils
    x11-utils
    x11-apps
    xfonts-base
    xfonts-75dpi
    xfonts-100dpi
    xfonts-utils
    shellcheck
    emacs
    make
    gcc
    perl-doc
    perltidy
    libfile-slurp-perl
    libpath-tiny-perl
    liblingua-en-inflect-perl
    libdevel-ptkdb-perl
    libjson-xs-perl
    libperl-tidy-perl
    cpanminus
    xdg-utils
    firefox
    yad
    semver
    rename
    wish
    smartmontools
    jq
    speech-dispatcher
)

declare debian_package
for debian_package in "${debian_packages[@]}"; do
    echo
    cmd-echo --id $ceid "$debian_package..."
    sudo apt install -y "$debian_package"
done

## Debian_Package related stuff
git config --global web.brower firefox

## Install homebrew packages
cmd-echo --id $ceid 'Install homebrew and its packages'
curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh > ./homebrew_install.sh || { false; exit; }
chmod +x ./homebrew_install.sh
echo "*** $(date)" >> homebrew_install.log
./homebrew_install.sh | tee -a homebrew_install.log

declare -a homebrew_packages=(
    uv
)

declare homebrew_package
for homebrew_package in "${homebrew_packages[@]}"; do
    echo
    cmd-echo --id $ceid "$homebrew_package..."
    brew install "$homebrew_package"
done

## Install python programs

## Build what we have
declare prog
for prog in /opt/mop/build/*; do
    (
        cd "$prog" || exit
        declare ver
        # shellcheck disable=SC2012 #https://github.com/koalaman/shellcheck/wiki/SC2012
        ver=$(ls -c1 | sort -V | tail -1)
        build-oss --clean "$prog" "$ver"
    )
done

declare sys_perl
sys_perl=$(which perl)
echo "export SYS_PERL=$sys_perl" >> ~/personal/bin/perl.mopenv

## Boostrap plenv
(
    cd /home/matthew || exit

    ## get plenv
    git clone https://github.com/tokuhirom/plenv.git .plenv

    ## Add to PATH
    # shellcheck disable=SC1091 #https://github.com/koalaman/shellcheck/wiki/SC1091
    . personal/bin/perl.mopenv

    ## This plugin builds perl itself in plenv
    git clone https://github.com/tokuhirom/Perl-Build.git .plenv/plugins/perl-build

    ## Build perls
    declare latest
    # shellcheck disable=SC2016 #https://github.com/koalaman/shellcheck/wiki/SC2016
    latest=$($sys_perl -ane '
        next if $_ =~ /Available/;
        @parts = split(/\./,$_);
        next if $parts[1]%2==1;
        chomp $_; print $_; exit;' < <(plenv install --list)
    )
    declare version
    for version in 5.16.3 "$latest"; do
        plenv install "$version"
        plenv rehash
    done

    ## Other goodies
    git clone https://github.com/miyagawa/plenv-contrib.git .plenv/plugins/plenv-contrib

    plenv exec-all cpanm \
          File::Slurp \
          Path::Tiny \
          Lingua::EN::Inflect \
          JSON::PP \
          JSON::XS \
          CPAN::Meta \
          Test::Fatal \
          Test::FailWarnings \
          Test::MockRandom \
          Unicode::UTF8 \
          Tk \
          Devel::ptkdb
)

#  LocalWords:  debian homebrew
