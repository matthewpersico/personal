# -*- sh -*-
# shellcheck shell=ksh

# find-an-xterm

if [[ -n "$XTERM" ]] ;then
    echo "$XTERM"
else
    declare i
    for i in /usr/bin/X11 /usr/bin /bin $HOME/EMPOPTGLOBALROOT/bin; do
        declare j
        for j in uxterm xterm; do
            if [[ -e "$i/$j" ]]; then
                echo "$i/$j"
                exit
            fi
        done
    done
fi
