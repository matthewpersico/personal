# -*- sh -*-
# shellcheck shell=bash

# util.mopenv

## Interactivity ##
STDIN=0;export STDIN
STDOUT=1;export STDOUT
STDERR=2;export STDERR

## includes (source) for bash
BASH_INC_DIR=$PERSONALBIN; export BASH_INC_DIR
addpath -fx BASH_INC_PATH "$BASH_INC_DIR"

## post-any-install aliases
alias pai-init="source \$HOME/personal/bin/post-any-install"
alias pai-edit="xo \$HOME/personal/bin/post-any-install"

## Guard variable
UTILENV_LOADED=1
export UTILENV_LOADED
