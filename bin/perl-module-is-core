#!/usr/bin/env perl
use strict;
use warnings;

use Module::CoreList;

my $verbose = 0;
if ( $ARGV[0] =~ /-v/ ) {
    $verbose = 1;
    shift @ARGV;
}

my $version = Module::CoreList->first_release( $ARGV[0] );

if ( defined $version ) {
    $verbose && print "$ARGV[0] first appeared in core in Perl version $version\n";
    exit 0;    # UNIX SUCCESS
} else {
    $verbose && print "$ARGV[0] is not a core module\n";
    exit 1;    # UNIX FAILURE
}
