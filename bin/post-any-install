##
## Build OSS stuff
##
pai-build-oss () {
    # Set up the install dir
    declare build_root="/opt/${pai_opt_short_user}/build"
    if [[ ! -d $build_root ]]; then
        sudo mkdir -p "${build_root}"
        sudo chown -R "${USER}:${USER}" "${build_root}"
    fi
    cd "${build_root}" || { false; exit; }
    github-clone matthewpersico/oss
    cd oss || { false; exit; }

    # Make or grab the current machine branch
    if github branch --list --all | grep "origin/$(hostname)"; then
        git checkout -b "$(hostname)" --track "origin/$(hostname)"
    else
        git checkout -b "$(hostname)" --track "origin/$(hostname)"
        git push -u origin "$(hostname)"
    fi

    # Build and install everything
    declare prog
    for prog in "${build_root}"/*; do
        (
            cd "$prog" || exit
            declare ver
            # shellcheck disable=SC2012 #https://github.com/koalaman/shellcheck/wiki/SC2012
            ver=$(ls -c1 | sort -V | tail -1)
            build-oss --clean "$prog" "$ver"
        )
    done

    # Set up the branch sync for the repo
    github-clone --tree matthewpersico/oss
    declare -a branches
    mapfile branches < <(git branch --list --remote | grep -v -- '->' | grep origin/ | sed 's/origin\///')
    for branch in "${branches[@]}"; do
        if ! git branch --list | grep -E "\* $branch$"; then
            git checkout -b "$branch" --track "origin/$branch"
        fi
    done
}

##
## plenv
##
pai-plenv () {
    declare sys_perl
    sys_perl=$(which perl)
    grep -v 'export SYS_PERL' ~/personal/bin/perl.mopenv > /tmp/pai.$$
    echo "export SYS_PERL=$sys_perl" >> /tmp/pai.$$
    mv /tmp/pai.$$ ~/personal/bin/perl.mopenv

    ## Boostrap plenv
    (
        cd "$HOME" || exit

        ## get plenv
        git clone https://github.com/tokuhirom/plenv.git .plenv

        ## Add to PATH
        . personal/bin/perl.mopenv

        ## This plugin builds perl itself in plenv
        git clone https://github.com/tokuhirom/Perl-Build.git .plenv/plugins/perl-build

        ## Build perls
        declare latest
        # shellcheck disable=SC2016 #https://github.com/koalaman/shellcheck/wiki/SC2016
        latest=$($sys_perl -ane '
        next if $_ =~ /Available/;
        @parts = split(/\./,$_);
        next if $parts[1]%2==1;
        chomp $_; print $_; exit;' < <(plenv install --list)
              )
        declare version
        for version in 5.16.3 "$latest"; do
            plenv install "$version"
            plenv rehash
        done

        ## Other goodies
        git clone https://github.com/miyagawa/plenv-contrib.git .plenv/plugins/plenv-contrib

        ## Load up modules
        plenv exec-all cpanm "${pai_perl_modules[@]}"
    )
}

main () {
    # Read the options and args from command line. Note that the long and short
    # don't have to match up.
    declare OPTSARGS
    declare shortopts=''
    declare longopts='user:,short_user:,os:'

    # Process the command line.
    OPTSARGS=$(getopt -a -o "$shortopts" -l "${longopts}" -n "${FUNCNAME[0]}" -- "$@") || return

    # Reset the command line ($@).
    eval set -- "$OPTSARGS"

    # Reprocess the command line, extracting options and their arguments into
    # variables.
    declare option
    while (( $# )); do
        option=$1
        shift

        # If the option does not exactly equal the end-of-options marker, strip
        # the lead dash(es) from the option.
        [[ "$option" != '--' ]] && option=${option##-} && option=${option##-}

        case $option in
            user )
                pai-ce "Overiding user ($pai_opt_user) with $option"
                pai_opt_user="$option"; shift
                ;;
            short_user )
                pai-ce "Overiding short user ($pai_opt_short_user) with $option"
                pai_opt_short_user="$option"; shift
                ;;
            os )
                case $option in
                    '' )
                        pai-ce --ec "--os not specified"
                        ;;

                    wsl | rpi )
                        pai_opt_os="$option"; shift
                        ;;

                    * )
                        pai-ce --ec "'$option' is an invalid value for --os"
                        ;;
                esac
                if [[ -z "$pai_opt_os" ]]; then
                    pai-ce --ec "Valid values for --os are 'wsl' and 'rpi'"
                    false; exit
                fi
                ;;
            * )
                pai-ce --ec "'$option' is an invalid option"
                false; exit
                ;;
        esac
    done

    if [[ $pai_opt_os == 'rpi' ]]; then
        pai-get-workspace
        pai-add-dpkg-repos
        pai-add-email-support
        pai-check-passwd
        pai-distro-debian-packages
        pai-local-debian-packages
        pai-homebrew
        pai-homebrew-packages
        pai-perlbrew
        pai-perlbrew-modules
        pai-build-oss
        pai-plenv
    elif [[ $pai_opt_os == 'wss' ]]; then
        pai-sudo
        pai-get-workspace
        pai-add-dpkg-repos
        pai-add-email-support
        pai-check-passwd
        pai-distro-debian-packages
        pai-local-debian-packages
        pai-homebrew
        pai-homebrew-packages
        pai-perlbrew
        pai-perlbrew-modules
        pai-build-oss
        pai-plenv
    fi
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
    main "$@"
else
    # shellcheck disable=SC2046 #https://github.com/koalaman/shellcheck/wiki/SC2046
    pai-ce "Script was sourced. No execution."\
           "The following functions are available:" \
           $(declare -F | grep pai- | sed 's/declare -f //' | grep -v -E '^\s*_')
fi

#  LocalWords:  debian homebrew
