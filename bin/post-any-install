pai-ce () {
    cmd-echo --id post-any-install "$@"
}

# pai-init is aliased in util.mopenv to prevent chicken-egg condition
# pai-edit is aliased in util.mopenv to prevent chicken-egg condition

##
## Set up sudo
##
pai-sudo () {
    pai-ce 'Set up sudo'

    declare sudoers_file=sudoers.$USER
    cat <<EOSUDOERS >"$sudoers_file"
$USER ALL=(ALL) NOPASSWD:ALL
EOSUDOERS

    sudo chown root:root "$sudoers_file"
    sudo chmod 664 "$sudoers_file"
    sudo mv "$sudoers_file" "/etc/sudoers.d/$USER"
    sudo ls -lart "/etc/sudoers.d/$USER"
}

##
## Create a workspace
##
pai-get-workspace () {
    pai_workspace=/opt/${pai_opt_short_user}/post-any-install
    if [[ ! -d $pai_workspace ]]; then
        sudo mkdir -p "/opt/${pai_opt_short_user}"
        sudo chown "${pai_opt_user}" "/opt/${pai_opt_short_user}"
        mkdir -p "$pai_workspace"
    fi
    cd "$pai_workspace" || exit
}

##
## Add dpkg repos
##
pai-add-dpkg-repos () {
    pai-ce 'Add dpkg repos'

    ## Brave browser
    sudo curl -fsSLo /usr/share/keyrings/brave-browser-archive-keyring.gpg https://brave-browser-apt-release.s3.brave.com/brave-browser-archive-keyring.gpg
    sudo curl -fsSLo /etc/apt/sources.list.d/brave-browser-release.sources https://brave-browser-apt-release.s3.brave.com/brave-browser.sources

    ##
    ## Update the system
    ##
    pai-ce 'Update the system'
    sudo apt update
    sudo apt upgrade
}

##
## Add email support, primarily for cron
##
pai-add-email-support () {
    pai-ce 'Add email support, primarily for cron'

    sudo apt install ssmtp -y

    cat <<EOSSMTPCONF > ssmtp.conf
root=matthew.persico@gmail.com
mailhub=smtp.gmail.com:587
hostname=MONOLITH.localdomain
FromLineOverride=YES
AuthUser=matthew.persico@gmail.com
AuthPass=$(cat /mnt/c/Users/matth/Documents/ssh/Gmail*.txt)
UseSTARTTLS=YES
EOSSMTPCONF

    sudo chown root:root ssmtp.conf
    sudo chmod 640 ssmtp.conf
    sudo mv ssmtp.conf /etc/ssmtp/ssmtp.conf
    sudo ls -lart /etc/ssmtp/ssmtp.conf
    sudo cat /etc/ssmtp/ssmtp.conf

    cat <<EOREVALIASES > revaliases
root:root@MONOLITH:smtp.gmail.com:587
${pai_opt_user}:${pai_opt_user}@MONOLITH:smtp.gmail.com:587
EOREVALIASES

    sudo chown root:root revaliases
    sudo chmod 640 revaliases
    sudo mv revaliases /etc/ssmtp/revaliases
    sudo ls -la /etc/ssmtp/revaliases
    sudo cat /etc/ssmtp/revaliases

    pai-ce 'Testing email setup'
    ssmtp matthew.persico@gmail.com <<EOD
Subject: This is a test
Line 1
Line 2
Line 3
EOD
}

pai-check-passwd() {
    if ! grep -q 'Matthew Persico' /etc/passwd; then
        pai-ce 'Name "Matthew Persico" not found in /etc/passwd. Add it...'
        sleep 2
        sudo vi /etc/passwd
    fi
}

pai-distro-debian-packages () {
    ##
    ## Install debian packages
    ##
    pai-ce 'Install debian packages from distribution'

    declare debian_package
    for debian_package in "${pai_debian_packages[@]}"; do
        echo
        pai-ce "$debian_package..."
        sudo apt install -y "$debian_package"
    done

    ## Debian_Package related stuff
    git config --global web.brower brave-browser
}

pai-local-debian-packages () {
    pai-ce 'Install local debian packages'
    declare -a ldebian_packages=(
    )

    declare ldebian_package
    declare -a fdebian_packages # f => fully wildcard expanded
    declare fdebian_package
    for ldebian_package in "${ldebian_packages[@]}"; do
        echo
        # shellcheck disable=SC2207 #https://github.com/koalaman/shellcheck/wiki/SC2207
        # shellcheck disable=SC2086 #https://github.com/koalaman/shellcheck/wiki/SC2086
        fdebian_packages=($(printf "%s\n" ${ldebian_package}*.deb | sed -e "s/^${ldebian_package}//" | sort -V | sed -e "s/^/${ldebian_package}/"))
        if [[ "${ldebian_package}*.deb" == "${fdebian_packages[0]}" ]]; then
            fdebian_packages=()
        fi
        if [[ ${#fdebian_packages[@]} == '0' ]]; then
            pai-ce -wc "$ldebian_package: No such package found."
            continue
        fi
        if (( ${#fdebian_packages[@]} > 1 )); then
            pai-ce -wc "$ldebian_package: More than one such package found."
            select fdebian_package in "${fdebian_packages[@]}" Quit
            do
                if [[ -n $fdebian_package ]]; then break; fi
            done
            pai-ce "selection: $fdebian_package ($REPLY)"
        else
            fdebian_package=${fdebian_packages[0]}
        fi
        if [[ $fdebian_package == 'Quit' ]] ; then break; fi
        pai-ce "$fdebian_package..."
        sudo apt install -y "$fdebian_package"
    done
}

##
## Install homebrew packages
##
pai-homebrew () {
    pai-ce 'Install homebrew and its packages'
    declare return_to
    return_to=$(pwd);

    pai-get-workspace

    curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh > ./homebrew_install.sh || { false; exit; }
    chmod +x ./homebrew_install.sh
    declare logfile
    logfile="homebrew_install.$(date +%Y-%m-%dT%H-%M-%S).log"
    pai-ce "Logfile is $logfile"
    (
        echo "*** $(date)"
        ./homebrew_install.sh
    ) 2>&1 | tee "$logfile"
    pai-ce "Logfile is $logfile"
    cd "$return_to" || { false; exit; }
}

pai-homebrew-packages () {
    api-cd - "Install homebrew packages"
    if [[ ! -f $HOME/personal/bin/homebrew.mopenv ]]; then
        pai-ce -ec "Environment file $HOME/personal/bin/homebrew.mopenv not found. No homebrew package installations will take place."
    else
        . "$HOME"/personal/bin/homebrew.mopenv

        declare return_to
        return_to=$(pwd)

        pai-get-workspace

        declare logfile
        logfile="$(pwd)/perlbrew_install.$(date +%Y-%m-%dT%H-%M-%S).log"
        pai-ce "Logfile is $logfile"
        (
            # Install
            declare homebrew_package
            declare homebrew_package_count="${#pai_homebrew_packages[@]}"
            declare homebrew_package_idx=0
            for homebrew_package in "${pai_homebrew_packages[@]}"; do
                echo
                ((homebrew_package_idx+=1))
                pai-ce "*********** $homebrew_package... ($homebrew_package_idx/$homebrew_package_count)  $(date)"
                brew install "$homebrew_package"
            done
        ) 2>&1 | tee "$logfile"
    fi

    pai-ce "Logfile is $logfile"
    cd "$return_to" || { false; exit; }
}

##
## Install perlbrew
##
_pai-perlbrew-make-alias-name () {
    declare perl_installation=$1
    declare perl_installation_alias
    perl_installation_alias=${perl_installation#perl-}
    perl_installation_alias=${perl_installation_alias%.*}
    echo "$perl_installation_alias"
}

pai-perlbrew () {
    pai-ce 'Install perlbrew and perl installations'
    declare return_to
    return_to=$(pwd);

    pai-get-workspace

    export PERLBREW_ROOT=/opt/mop/perlbrew
    curl -L https://install.perlbrew.pl > ./perlbrew_install.sh || { false; exit; }
    chmod +x ./perlbrew_install.sh

    declare logfile_root
    logfile_root="$(pwd)/perlbrew_install.$(date +%Y-%m-%dT%H-%M-%S)"

    declare logfile
    logfile="${logfile_root}.brew.log"
    pai-ce "Logfile is $logfile"
    (
        echo "*** $(date)"
        ./perlbrew_install.sh

        declare perlbrew_rc=$PERLBREW_ROOT/etc/bashrc
        if ! grep $perlbrew_rc "$HOME/personal/bin/perl.mopenv" ; then
            pai-ce "Adding '$perlbrew_rc' to '$HOME/personal/bin/perl.mopenv'..."
            cat << EOF >> "$HOME/personal/bin/perl.mopenv"

if [[ -f $perlbrew_rc ]]; then
    . $perlbrew_rc
fi

EOF
        else
            pai-ce "'$perlbrew_rc' already in '$HOME/personal/bin/perl.mopenv'..."
        fi

        # shellcheck disable=SC1090 #https://github.com/koalaman/shellcheck/wiki/SC1090
        source "$perlbrew_rc"
        perlbrew install-patchperl
    ) 2>&1 | tee "$logfile"
    pai-ce "Logfile is $logfile"

    # List of perl versions we care about
    declare -a perl_installations_to_install
    if [[ -n $1 ]]; then
        perl_installations_to_install=("$@")
    else
        perl_installations_to_install=("${pai_perl_installations[@]}")
    fi

    pai-ce "Installing perl versions ${perl_installations_to_install[*]}"

    declare perl_installation
    for perl_installation in "${perl_installations_to_install[@]}"; do
        logfile="${logfile_root}.${perl_installation}.log"
        pai-ce "Logfile is $logfile"
        (
            if perlbrew install "$perl_installation"; then

                # Alias
                declare perl_installation_alias
                perl_installation_alias=$(_pai-perlbrew-make-alias-name "$perl_installation")
                if perlbrew alias create "$perl_installation" "$perl_installation_alias" 2>&1 | grep -q 'already exists'; then
                    declare existing_alias_value
                    existing_alias_value=$(perlbrew exec --with "$perl_installation_alias" perl -e '$v=$^V;$v=~s/v/perl-/;print $v')
                    pai-ce "Moving existing alias $perl_installation_alias from $existing_alias_value to $perl_installation"
                    perlbrew alias delete "$perl_installation_alias"
                    perlbrew alias create "$perl_installation" "$perl_installation_alias"
                else
                    pai-ce "Created $perl_installation_alias as an alias for $perl_installation"
                fi

                # Locally built modules
                # - TK
                echo "cd ~/gits/github/matthewpersico/perl-tk/wt/fix-rt-154121; perl Makefile.PL; make install"
            fi
        ) 2>&1 | tee "$logfile"
        pai-ce "Logfile is $logfile"
    done
    cd "$return_to" || { false; exit; }
}

pai-perlbrew-tk () {
    pai-ce "Install CPAN modules to perlbrew"

    # shellcheck disable=SC2031 #https://github.com/koalaman/shellcheck/wiki/SC2031
    if [[ -z $PERLBREW_ROOT ]]; then
        pai-ce "perlbrew not initialized in this shell. Will source \"$PERLBREW_ROOT/etc/bashrc\"."
        source "$PERLBREW_ROOT/etc/bashrc"
    fi

    declare return_to
    return_to=$(pwd);

    pai-get-workspace

    declare logfile
    logfile="$(pwd)/perlbrew_tk_install.$(date +%Y-%m-%dT%H-%M-%S).log"
    pai-ce "Logfile is $logfile"
    (
        # Bootstrap. This installation is good across all perlbrew perls.
        perlbrew install-cpanm

        # List of perl versions we care about
        declare -a perl_installations_to_use
        if [[ -n $1 ]]; then
            perl_installations_to_use=("$@")
        else
            perl_installations_to_use=("${pai_perl_installations[@]}")
        fi

        pai-ce "Building TK for ${perl_installations_to_use[*]}"

        # Install Tk
        cd ~/gits/github/matthewpersico/perl-tk/wt/fix-rt-154121 || exit
        for perl_exe in "${perl_installations_to_use[@]}"; do
            perlbrew use "$perl_exe"
            git drc
            perl Makefile.PL
            make #|| exit
            pause
            make test #|| exit
            pause
            make install #|| exit
        done
        set +x
    ) 2>&1 | tee "$logfile"
    pai-ce "Logfile is $logfile"
    cd "$return_to" || { false; exit; }
}

pai-perlbrew-modules () {
    pai-ce "Install CPAN modules to perlbrew"

    # shellcheck disable=SC2031 #https://github.com/koalaman/shellcheck/wiki/SC2031
    if [[ -z $PERLBREW_ROOT ]]; then
        pai-ce "perlbrew not initialized in this shell. Will source \"$PERLBREW_ROOT/etc/bashrc\"."
        source $PERLBREW_ROOT/etc/bashrc
    fi

    declare return_to
    return_to=$(pwd);

    pai-get-workspace

    declare logfile
    logfile="$(pwd)/perlbrew_install.$(date +%Y-%m-%dT%H-%M-%S).log"
    pai-ce "Logfile is $logfile"
    (
        # Bootstrap. This installation is good across all perlbrew perls.
        perlbrew install-cpanm

        # List of perl versions we care about
        declare perl_installations
        if [[ -n $1 ]]; then
            ajoin perl_installations -s , "$@"
        else
            ajoin perl_installations -s , "${pai_perl_installations[@]}"
        fi
        pai-ce "Installing modules in $perl_installations"

        # Install
        declare perl_module
        declare perl_module_count="${#pai_perl_modules[@]}"
        declare perl_module_idx=0
        for perl_module in "${pai_perl_modules[@]}"; do
            echo
            ((perl_module_idx+=1))
            pai-ce "*********** $perl_module... ($perl_module_idx/$perl_module_count)  $(date)"
            perlbrew exec --with "$perl_installations" cpanm "$perl_module"
        done
    ) 2>&1 | tee "$logfile"
    pai-ce "Logfile is $logfile"
    cd "$return_to" || { false; exit; }
}

pai-system-perl-modules () {
    ##
    ## Install perl modules from the debian packages first, CPAN if there is no debian package.
    ##
    pai-ce 'Install Perl modules as debian packages, CPAN only if necessary.'

    declare perlbrew_return="$PERLBREW_PERL"
    if [[ -n "$perlbrew_return" ]]; then
        perlbrew off
    fi

    # Bootstrap cpan
    pai-ce "cpan bootstraps"
    sudo cpan install CPAN

    pai-ce "Update cpan itself..."
    sudo cpan install Log::Log4perl Text::Levenshtein App::cpanminus

    pai-ce "Now using the list..."
    declare perl_module
    for perl_module in "${!pai_system_perl_modules[@]}"; do
        echo
        declare sys=${pai_system_perl_modules[$perl_module]}
        case $sys in
            debian)
                pai-ce "$perl_module..."
                sudo apt install "$perl_module"
                ;;
            cpan)
                declare pm="$perl_module"
                pm="${pm//__/::}"
                pai-ce "$pm..."
                sudo cpanm "$pm"
                ;;
        esac
    done
    if [[ -n "$perlbrew_return" ]]; then
        perlbrew switch "$perlbrew_return"
    fi
}

