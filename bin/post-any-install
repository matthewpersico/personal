# -*- sh -*-
# shellcheck shell=bash
# shellcheck disable=SC1091 #https://github.com/koalaman/shellcheck/wiki/SC1091

## post-any-install
## Instructions to build an environment after a new install.
## Run as 'matthew'; 'sudo' will be used where necessary.

declare pai_opt_user=$USER
declare pai_opt_short_user=mop
declare pai_opt_os=''
declare -a pai_perl_modules=(
    App::cpanminus
    Term::ReadKey
    Log::Log4perl
    Text::Levenshtein
    Config
    Cwd
    Data::Dumper
    Tk
    Devel::ptkdb
    Email::Sender
    Email::Simple
    Fcntl
    File::Basename
    File::Copy
    File::Slurp
    File::Spec
    File::Temp
    File::stat
    FindBin
    Getopt::Long
    IO::Dir
    IO::File
    IPC::Cmd
    JSON::PP
    JSON::XS
    Lingua::EN::Inflect
    List::MoreUtils
    List::MoreUtils::XS
    Module::Starter
    Module::Starter::PBP
    MIME::Base64
    POSIX
    Path::Tiny
    Perl::Tidy
    Pod::Usage
    Rand::Urandom
    Scalar::Util
    Sys::Hostname
    Term::Menus
    Term::ReadLine
    Term::UI
    Test::More
    Text::Wrap
)

pai-ce () {
    cmd-echo --id post-any-install "$@"
}

##
## Set up sudo
##
pai-sudo () {
    pai-ce 'Set up sudo'

    declare sudoers_file=sudoers.$USER
    cat <<EOSUDOERS >"$sudoers_file"
$USER ALL=(ALL) NOPASSWD:ALL
EOSUDOERS

    sudo chown root:root "$sudoers_file"
    sudo chmod 664 "$sudoers_file"
    sudo mv "$sudoers_file" "/etc/sudoers.d/$USER"
    sudo ls -lart "/etc/sudoers.d/$USER"
}

##
## Create a workspace
##
pai-create-workspace () {
    sudo mkdir -p "/opt/${pai_opt_short_user}"
    sudo chown "${pai_opt_user}" "/opt/${pai_opt_short_user}"
    declare install_workdir
    install_workdir=/opt/${pai_opt_short_user}/$(basename "$0")
    mkdir -p "$install_workdir"
    cd "$install_workdir" || exit
}

##
## Add dpkg repos
##
pai-add-dpkg-repos () {
    pai-ce 'Add dpkg repos'
    sudo apt-add-repository ppa:git-core/ppa

    ##
    ## Update the system
    ##
    pai-ce 'Update the system'
    sudo apt update
    sudo apt upgrade
}

##
## Add email support, primarily for cron
##
pai-add-email-support () {
    pai-ce 'Add email support, primarily for cron'

    sudo apt install ssmtp -y

    cat <<EOSSMTPCONF > ssmtp.conf
root=matthew.persico@gmail.com
mailhub=smtp.gmail.com:587
hostname=MONOLITH.localdomain
FromLineOverride=YES
AuthUser=matthew.persico@gmail.com
AuthPass=$(cat /mnt/c/Users/matth/Documents/ssh/Gmail*.txt)
UseSTARTTLS=YES
EOSSMTPCONF

    sudo chown root:root ssmtp.conf
    sudo chmod 640 ssmtp.conf
    sudo mv ssmtp.conf /etc/ssmtp/ssmtp.conf
    sudo ls -lart /etc/ssmtp/ssmtp.conf
    sudo cat /etc/ssmtp/ssmtp.conf

    cat <<EOREVALIASES > revaliases
root:root@MONOLITH:smtp.gmail.com:587
${pai_opt_user}:${pai_opt_user}@MONOLITH:smtp.gmail.com:587
EOREVALIASES

    sudo chown root:root revaliases
    sudo chmod 640 revaliases
    sudo mv revaliases /etc/ssmtp/revaliases
    sudo ls -la /etc/ssmtp/revaliases
    sudo cat /etc/ssmtp/revaliases

    pai-ce 'Testing email setup'
    ssmtp matthew.persico@gmail.com <<EOD
Subject: This is a test
Line 1
Line 2
Line 3
EOD
}

pai-check-passwd() {
    if ! grep -q 'Matthew Persico' /etc/passwd; then
        pai-ce 'Name "Matthew Persico" not found in /etc/passwd. Add it...'
        sleep 2
        sudo vi /etc/passwd
    fi
}

pai-distro-debian-packages () {
    ##
    ## Install debian packages
    ##
    pai-ce 'Install debian packages from distribution'

    declare -a debian_packages=(
        build-essential
        curl
        x11-xserver-utils
        x11-utils
        x11-apps
        xfonts-base
        xfonts-75dpi
        xfonts-100dpi
        xfonts-utils
        libxaw7-dev
        libxaw7
        libxaw-doc
        libmotif-dev
        shellcheck
        emacs
        make
        gcc
        perl-doc
        xdg-utils
        firefox
        yad
        semver
        rename
        wish
        smartmontools
        jq
        speech-dispatcher
        code ## This is vscode. Way to go Microsoft with the naming...
    )

    declare debian_package
    for debian_package in "${debian_packages[@]}"; do
        echo
        pai-ce "$debian_package..."
        sudo apt install -y "$debian_package"
    done

    ## Debian_Package related stuff
    git config --global web.brower firefox
}

pai-local-debian-packages () {
    pai-ce 'Install local debian packages'
    declare -a ldebian_packages=(
    )

    declare ldebian_package
    declare -a fdebian_packages # f => fully wildcard expanded
    declare fdebian_package
    for ldebian_package in "${ldebian_packages[@]}"; do
        echo
        # shellcheck disable=SC2207 #https://github.com/koalaman/shellcheck/wiki/SC2207
        # shellcheck disable=SC2086 #https://github.com/koalaman/shellcheck/wiki/SC2086
        fdebian_packages=($(printf "%s\n" ${ldebian_package}*.deb | sed -e "s/^${ldebian_package}//" | sort -V | sed -e "s/^/${ldebian_package}/"))
        if [[ "${ldebian_package}*.deb" == "${fdebian_packages[0]}" ]]; then
            fdebian_packages=()
        fi
        if [[ ${#fdebian_packages[@]} == '0' ]]; then
            pai-ce -wc "$ldebian_package: No such package found."
            continue
        fi
        if (( ${#fdebian_packages[@]} > 1 )); then
            pai-ce -wc "$ldebian_package: More than one such package found."
            select fdebian_package in "${fdebian_packages[@]}" Quit
            do
                if [[ -n $fdebian_package ]]; then break; fi
            done
            echo "selection: $fdebian_package ($REPLY)"
        else
            fdebian_package=${fdebian_packages[0]}
        fi
        if [[ $fdebian_package == 'Quit' ]] ; then break; fi
        pai-ce "$fdebian_package..."
        sudo apt install -y "$fdebian_package"
    done
}

##
## Install homebrew packages
##
pai-homebrew-packages () {
    pai-ce 'Install homebrew and its packages'
    curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh > ./homebrew_install.sh || { false; exit; }
    chmod +x ./homebrew_install.sh
    echo "*** $(date)" >> homebrew_install.log
    ./homebrew_install.sh | tee -a homebrew_install.log

    if [[ ! -f $HOME/personal/bin/homebrew.mopenv ]]; then
        pai-ce -ec "Environment file $HOME/personal/bin/homebrew.mopenv not found. No homebrew installations will take place."
    else
        . "$HOME"/personal/bin/homebrew.mopenv
        declare -a homebrew_packages=(
            gcc
            uv
            bashdb
        )

        declare homebrew_package
        for homebrew_package in "${homebrew_packages[@]}"; do
            echo
            pai-ce "$homebrew_package..."
            brew install "$homebrew_package"
        done
    fi
}

pai-perl-modules () {
    ##
    ## Install perl modules to get later versions of OS packaged Perl modules
    ## we used to bootstrap and other needed packages.
    ##
    pai-ce 'Install Perl modules from cpan'

    # Bootstrap cpan
    pai-ce "cpan boostraps"
    sudo cpan install CPAN
    pai-ce "Update cpan itself..."
    sudo cpan install Log::Log4perl Text::Levenshtein App::cpanminus
    pai-ce "Log::Log4perl Text::Levenshtein App::cpanminus"

    pai-ce "Now using cpanm..."
    declare perl_module
    for perl_module in "${pai_perl_modules[@]}"; do
        echo
        pai-ce "$perl_module..."
        sudo cpanm install "$perl_module"
    done
}

