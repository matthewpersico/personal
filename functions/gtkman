# -*- sh -*-
# shellcheck shell=bash

# gtkman

# <Function Class: alias>
# <Function Justification: backgrounding>

gtkman ()
{
    if [[ $1 =~ ^-{1,2}h ]]; then
        bash-usage "${FUNCNAME[0]}" man "${FUNCNAME[0]}"
        { true; return; }
    else
        command "${FUNCNAME[0]}" "$@" &
    fi
}

:<<'__PODUSAGE__'
=head1 NAME

gtkman - run gtkman in background mode, always.

=head1 DESCRIPTION

 gtkman opts and args
 gtkman -h|-help

This function exists just to force the backgrounding. All other behavior is the
same.

If you B<really> don't want your gtkman call backgrounded, then call it

    command gtkman

and this function will be skipped in the shell command lookup.

=cut

__PODUSAGE__
