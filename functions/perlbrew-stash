# -*- sh -*-
# shellcheck shell=bash

# perlbrew

# A wrapper around 'perlbrew' to extend it. See the docs at file's end.
perlbrew-stash ()
{
    local moreopts=1
    while (( moreopts)); do
        if [[ $1 =~ -{0,1}-h ]]; then
            bash-usage perlbrew-stash
            true; return
        else
            moreopts=0
        fi
    done

    if [[ -n "$PERLBREW_PERL_LAST" ]]; then
        echo "Cannot stash '$PERLBREW_PERL' as PERLBREW_PERL_LAST (and PBPL). PERLBREW_PERL_LAST is currently set to '$PERLBREW_PERL_LAST'."
        false; return
    fi
    echo "Storing $PERLBREW_PERL as PERLBREW_PERL_LAST (and PBPL)"
    export PERLBREW_PERL_LAST=$PERLBREW_PERL
    export PBPL=$PERLBREW_PERL
}

autotrack perlbrew "$0"

:<<'__PODUSAGE__'
=head1 NAME

perlbrew-stash - Save the current version of Perl running in perlbrew

=head1 SYNOPSIS

 $ perlbrew-stash

 Storing perl-5.42.2

=head1 DESCRIPTION

Save PERLBREW_PERL as PERLBREW_PERL_LAST (and PBPL) so we can

  perlbrew off
  # do some work with system perl
  perlbrew use $PBPL

instead of having to remember the last version of perl we are using and then
type it out.

=head1 OPTIONS

=over 4

=item --help | -h

Show this text.

=back

=cut

__PODUSAGE__
