# -*- sh -*-
# shellcheck shell=bash

# perlbrew

# A wrapper around 'perlbrew' to extend it. See the docs at file's end.
perlbrew-pop ()
{
    local moreopts=1
    while (( moreopts)); do
        if [[ $1 =~ -{0,1}-h ]]; then
            bash-usage perlbrew-pop
            true; return
        else
            moreopts=0
        fi
    done

    if [[ -z "$PERLBREW_PERL_LAST" ]]; then
        echo "Cannot recover last perlbrew version. PERLBREW_PERL_LAST is not defined".
        false; return
    fi
    echo "$PERLBREW_PERL_LAST"
    unset PBPL
    unset PERLBREW_PERL_LAST
}

autotrack perlbrew "$0"

:<<'__PODUSAGE__'
=head1 NAME

perlbrew-store - Save the current version of Perl running in perlbrew

=head1 SYNOPSIS

 $ perlbrew-pop

 perl-5.42.2

=head1 DESCRIPTION

Print PERLBREW_PERL_LAST to stdout and then unset PERLBREW_PERL_LAST (and PBPL) so we can

  perlbrew off
  # do some work with system perl
  perlbrew use $(perlbrew-pop)

instead of having to remember the last version of perl we are using and then
type it out.

Despite the name of '-pop', there is no stack of versions maintained.

=head1 OPTIONS

=over 4

=item --help | -h

Show this text.

=back

=cut

__PODUSAGE__
