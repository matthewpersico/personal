# -*- sh -*-
# shellcheck shell=bash

# tkpod

# <Function Class: alias>
# <Function Justification: backgrounding>

tkpod ()
{
    if [[ $1 =~ ^-{1,2}h ]]; then
        bash-usage "${FUNCNAME[0]}" man "${FUNCNAME[0]}"
        { true; return; }
    else
        command "${FUNCNAME[0]}" "$@" &
    fi
}

:<<'__PODUSAGE__'
=head1 NAME

tkpod - run tkpod in background mode, always.

=head1 DESCRIPTION

 tkpod opts and args
 tkpod -h|-help

This function exists just to force the backgrounding. All other behavior is the
same.

If you B<really> don't want your tkpod call backgrounded, then call it

    command tkpod

and this function will be skipped in the shell command lookup.

=cut

__PODUSAGE__
